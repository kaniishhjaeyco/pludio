# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# From the Stripe CLI (`stripe listen`) or the Dashboard webhook endpoint.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Supabase (service role key — server-side only, never expose to the browser)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Table holding per-user subscription flags (defaults to "users").
SUPABASE_TABLE=users

# Optional: pin the base URL used for Checkout success/cancel redirects.
# If unset, it is derived from the incoming request host.
# PUBLIC_BASE_URL=https://pludio.com
